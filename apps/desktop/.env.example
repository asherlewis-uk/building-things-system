# Optional app URL for self-referential links and local preview metadata.
# Leave empty to keep the app fully local with no explicit external origin.
APP_URL=""

# Optional Appwrite integration.
# Leave every APPWRITE_* value empty to keep the shell fully local.
# Endpoint + project ID enable server-side reachability checks only.
APPWRITE_ENDPOINT=""
APPWRITE_PROJECT_ID=""

# Required only when APPWRITE_AUTH_MODE="anonymous".
# This enables the managed guest identity bootstrap used in this pass.
APPWRITE_API_KEY=""

# Supported values: "off" or "anonymous".
# "off" keeps Appwrite identity disabled even if the other vars are set.
APPWRITE_AUTH_MODE="off"
